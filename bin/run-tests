#! /usr/bin/env bash

set -e

export THIS_DIR=$(cd $(dirname "${BASH_SOURCE[$((${#BASH_SOURCE[@]} - 1))]}"); pwd)

ROOT_DIR="$THIS_DIR/.."

dart pub get
(cd "$ROOT_DIR/example"; dart pub get)

(cd "$ROOT_DIR"; dart analyze --fatal-infos)

(cd "$ROOT_DIR"; dart test)

(cd "$ROOT_DIR/example"; dart analyze)
